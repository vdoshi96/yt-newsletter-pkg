# Postgres (Neon, Vercel Postgres, Supabase, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Gemini (default model is gemini-2.5-flash — good balance of quality vs cost)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# Optional: max characters of transcript sent to Gemini (default 80000, max 100000)
# GEMINI_MAX_INPUT_CHARS=80000

# NBA roster for team resolution (stats.nba.com API — same data as NBA.com)
# SKIP_NBA_ROSTER=1
# Optional: force season string if auto-detection is wrong (format 2025-26)
# NBA_SEASON_ID=2025-26

# Cost / safety (web cron only)
# Max NEW videos to fully process per cron invocation (default 1). Stops email/Gemini storms if many uploads are pending.
# MAX_VIDEOS_PER_CRON=1
# Optional: max saved analyses per UTC calendar day (0 = unlimited). Counts rows in DB from successful pipeline runs.
# MAX_GEMINI_CALLS_PER_UTC_DAY=80

# Gmail (or other SMTP)
EMAIL_FROM=
EMAIL_TO=
EMAIL_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Dashboard login (pick a strong password)
CONTROLLER_PASSWORD=

# Session signing (min 16 chars, random)
SESSION_SECRET=

# Vercel Cron + manual triggers: same secret as in Vercel project → Cron Jobs → CRON_SECRET
CRON_SECRET=
